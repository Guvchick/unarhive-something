# ── Обязательно ──────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── Локальный Telegram Bot API (снимает лимит 50 МБ → 2 ГБ) ─────────────────
# Получить на https://my.telegram.org/apps → "API development tools"
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# URL задаётся автоматически через docker-compose; вручную не нужен

# ── Опционально ───────────────────────────────────────────────────────────────
# Telegram user ID для уведомлений о запуске/остановке (узнать у @userinfobot)
ADMIN_ID=

# Уровень логов: DEBUG | INFO | WARNING | ERROR  (по умолчанию: INFO)
LOG_LEVEL=INFO
